# DEV: пока бэкенд работает на ngrok-туннеле. Поменять на боевой домен после деплоя.
# ВАЖНО: при запросах к ngrok нужен заголовок `ngrok-skip-browser-warning: true`,
# иначе вместо JSON прилетит HTML-баннер. Это учтёт api-клиент бота и webapp-а.

# Telegram bot — get from @BotFather (use a test bot for development)
TELEGRAM_BOT_TOKEN=

# Bot username without @ — used in QR deep-links (https://t.me/<username>?start=...)
TG_BOT_USERNAME=corpmeet_dev_bot

# Internal secret shared with backend — required for /api/v1/internal/* endpoints
BOT_SECRET=

# Backend API base URL
BACKEND_URL=https://shove-thesaurus-speed.ngrok-free.dev

# Mini App public URL — must be HTTPS (use ngrok in dev, real domain in prod)
WEBAPP_URL=https://tg.corpmeet.uz

# Optional: notification group chat id (negative for groups)
GROUP_ID=

# Webapp build — baked into bundle by Vite at build time. Read by @corpmeet/design.
VITE_API_URL=https://corpmeet.uz
