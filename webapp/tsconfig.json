{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "types": ["vitest/globals", "@testing-library/jest-dom"],

    "baseUrl": ".",
    "paths": {
      "@corpmeet/design/theme": ["./src/types/shims/corpmeet-theme"],
      "@corpmeet/design/animations": ["./src/types/shims/corpmeet-animations"],
      "@corpmeet/design/complex": ["./src/types/shims/corpmeet-complex"],
      "@corpmeet/design/components": ["./src/types/shims/corpmeet-components"]
    }
  },
  "include": ["src", "tests"]
}
